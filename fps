local backroomsFolder = workspace:FindFirstChild("__THINGS")
if backroomsFolder then
    backroomsFolder = backroomsFolder:FindFirstChild("__INSTANCE_CONTAINER")
    if backroomsFolder then
        backroomsFolder = backroomsFolder:FindFirstChild("Active")
