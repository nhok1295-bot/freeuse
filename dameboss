
-- ========================================================
-- CONFIG AUTO UPGRADE EVENT
-- ========================================================
getgenv().AutoUpgradeBossDamage = true    -- Trạng thái mặc định khi chạy script
local DELAY_TIME = 0.3                     -- Thời gian chờ giữa mỗi lần mua (giây)

-- Cache các dịch vụ hệ thống nhằm tối ưu hóa CPU
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local NetworkFolder = ReplicatedStorage:WaitForChild("Network", 15)

if not NetworkFolder then return end

local UpgradeRemote = NetworkFolder:WaitForChild("EventUpgrades: Purchase", 10)
if not UpgradeRemote then return end

local upgradeArgs = { "BackroomsDeepBossDamage" }

-- ========================================================
-- TẠO GIAO DIỆN ĐIỀU KHIỂN (GUI NÚT BẤM ON/OFF)
-- ========================================================
local CoreGui = game:GetService("CoreGui")
if CoreGui:FindFirstChild("BossDamageUpgradeGUI") then
    CoreGui.BossDamageUpgradeGUI:Destroy()
end

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "BossDamageUpgradeGUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = CoreGui

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 180, 0, 35)
toggleBtn.Position = UDim2.new(0, 10, 0, 310) -- Nằm góc trái màn hình (dưới bảng ScanGUI cũ)
toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 80) -- Màu xanh lá mặc định (ON)
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 13
toggleBtn.Text = "AUTO BOSS DAME: ON"
toggleBtn.Parent = screenGui

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(0, 6)
uiCorner.Parent = toggleBtn

-- Hàm cập nhật trạng thái màu sắc và chữ của nút bấm
local function updateButtonDisplay()
    if getgenv().AutoUpgradeBossDamage then
        toggleBtn.Text = "AUTO BOSS DAME: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 80) -- Màu xanh lá
    else
        toggleBtn.Text = "AUTO BOSS DAME: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(150, 30, 30) -- Màu đỏ
    end
end

-- Xử lý sự kiện khi click vào nút bấm trên màn hình
toggleBtn.MouseButton1Click:Connect(function()
    getgenv().AutoUpgradeBossDamage = not getgenv().AutoUpgradeBossDamage
    updateButtonDisplay()
    
    -- Nếu người dùng chủ động BẬT lại, kích hoạt lại luồng chạy nền
    if getgenv().AutoUpgradeBossDamage then
        startUpgradeLoop()
    end
end)

-- ========================================================
-- LUỒNG XỬ LÝ NÂNG CẤP CHẠY NỀN
-- ========================================================
function startUpgradeLoop()
    task.spawn(function()
        while getgenv().AutoUpgradeBossDamage do
            local success, result = pcall(function()
                return UpgradeRemote:InvokeServer(unpack(upgradeArgs))
            end)
            
            if success then
                -- Nếu Server trả về kết quả thất bại (Thường do không đủ coin để mua cấp tiếp theo)
                if result == false or result == nil then
                    getgenv().AutoUpgradeBossDamage = false
                    updateButtonDisplay() -- Chuyển nút sang màu đỏ OFF
                    break
                end
            end
            
            task.wait(DELAY_TIME)
        end
    end)
end

-- Khởi chạy luồng nâng cấp ngay khi thực thi kịch bản
startUpgradeLoop()
