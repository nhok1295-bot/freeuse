local webhookURL = getgenv().WebhookURL
local DiscordUserID = getgenv().WebhookUserID
local playerName = game.Players.LocalPlayer.Name
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local libraryFolder = ReplicatedStorage:WaitForChild("Library", 30)
if libraryFolder then
    local ClientFolder = libraryFolder:WaitForChild("Client", 15)
    local InstancingCmds = require(ClientFolder:WaitForChild("InstancingCmds"))
    local FFlags = require(ClientFolder:WaitForChild("FFlags"))
    
    local joinTarget = FFlags.Get(FFlags.Keys.SideJoinEventTarget)
    if joinTarget then
        InstancingCmds.Enter(joinTarget, nil, true, "You are joining the minigame!")
    end
end

task.wait(10)

local Breakables = workspace.__THINGS.Breakables
local bosses = 0

for _, breakable in ipairs(Breakables:GetChildren()) do
    if breakable:IsA("Model") and breakable:GetAttribute("BreakableID") == "Daydream Mimic Boss2" then
        bosses = bosses + 1
    end
end

if bosses >= 3 then
    local serverJobId = game.JobId
    local placeId = game.PlaceId
    local playerCount = #game.Players:GetPlayers()
    
    local description = "🎉 **" .. playerName .. "** đã tìm thấy server có **" .. bosses .. "** Boss!\n"
    description = description .. "Server JobId: `" .. serverJobId .. "`\n"
    description = description .. "Place ID: `" .. placeId .. "`\n"
    description = description .. "Số người chơi: " .. playerCount .. "\n"
    description = description .. "Số boss: **" .. bosses .. "**"
    
    if webhookURL ~= "" then
        pcall(function()
            syn.request({
                Url = webhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    content = DiscordUserID ~= "" and "<@" .. DiscordUserID .. ">" or "",
                    embeds = {{
                        title = "🔥 TIM THAY SERVER NHIEU BOSS",
                        description = description,
                        color = 16711680,
                        footer = {text = "Pet Simulator 99 - Boss Scanner"},
                        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
                    }}
                })
            })
        end)
    end
else
    local placeId = game.PlaceId
    pcall(function()
        TeleportService:Teleport(placeId, game.Players.LocalPlayer)
    end)
end
